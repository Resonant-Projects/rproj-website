---
import favIcon from '~/assets/favicons/favicon.ico';
import favIconSvg from '~/assets/favicons/favicon.svg';
import appleTouchIcon from '~/assets/favicons/apple-touch-icon.png';
---

<link rel="shortcut icon" href={favIcon} transition:persist />
<link rel="icon" type="image/svg+xml" href={favIconSvg.src} transition:persist />
<link rel="mask-icon" href={favIconSvg.src} color="#8D46E7" transition:persist />
<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} transition:persist />
