---
import { SEARCH_PARAM } from '~/utils/search-routing';

export interface Props {
  class?: string;
  placeholder?: string;
}

const { class: className = '', placeholder = 'Search RR Resources...' } = Astro.props;
---

<div class={`rr-search ${className}`}>
  <form id="resource-search-form" class="relative" data-resource-search-form>
    <input
      type="text"
      id="resource-search-input"
      name={SEARCH_PARAM}
      placeholder={placeholder}
      class="bg-muted/50 placeholder-muted-foreground w-full rounded-md border border-border px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
      data-resource-search-input
    />
    <button
      type="submit"
      class="text-muted-foreground absolute right-3 top-1/2 -translate-y-1/2 transform transition-colors hover:text-primary"
      aria-label="Search"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </button>
  </form>
</div>

<script>
  import { SEARCH_PARAM } from '~/utils/search-routing';
  import { initSearchForm } from '~/scripts/search-form';

  const initResourceSearch = () =>
    initSearchForm({
      formSelector: '[data-resource-search-form]',
      inputSelector: '[data-resource-search-input]',
      searchParam: SEARCH_PARAM,
    });

  document.addEventListener('astro:page-load', initResourceSearch);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initResourceSearch);
  } else {
    initResourceSearch();
  }
</script>
