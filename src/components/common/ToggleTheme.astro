---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
  iconName?: string;
}

const {
  label = 'Toggle between Light and Dark mode',
  class:
    className = 'text-muted dark:text-brand-400 hover:bg-brand-100 dark:hover:bg-brand-700 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 rounded-lg text-sm p-3 inline-flex items-center',
  iconClass = 'w-6 h-6',
  iconName = 'tabler:sun',
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(':only')) && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name={iconName} class={iconClass} />
    </button>
  )
}
