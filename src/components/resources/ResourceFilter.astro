---
import { SEARCH_PARAM, buildResourcesUrl } from '~/utils/search-routing';

export interface Props {
  categories: string[];
  types: string[];
  selectedCategory?: string;
  selectedType?: string;
  class?: string;
}

const { categories, types, selectedCategory, selectedType, class: className = '' } = Astro.props;

// Get current search query from URL
const urlParams = new URLSearchParams(Astro.url.search);
const searchQuery = urlParams.get(SEARCH_PARAM);
---

<div class={`rr-filter mb-8 ${className}`}>
  <!-- Category Filter -->
  <div class="mb-6">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-xl font-bold text-foreground">Filter by Category</h2>
      {
        selectedCategory && (
          <a
            href={buildResourcesUrl({ category: undefined, type: selectedType, page: 1 }, searchQuery || undefined)}
            class="text-sm text-primary transition-colors hover:text-accent"
          >
            Clear category
          </a>
        )
      }
    </div>

    <div class="flex flex-wrap gap-2">
      {
        categories.map(category => (
          <a
            href={buildResourcesUrl({ category, type: selectedType, page: 1 }, searchQuery || undefined)}
            class={`rounded-full px-3 py-2 text-sm font-medium transition-colors ${
              selectedCategory === category
                ? 'bg-primary text-white'
                : 'hover:bg-muted-foreground/20 bg-muted text-foreground'
            }`}
          >
            {category}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Type Filter -->
  <div class="mb-6">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-xl font-bold text-foreground">Filter by Type</h2>
      {
        selectedType && (
          <a
            href={buildResourcesUrl({ category: selectedCategory, type: undefined, page: 1 }, searchQuery || undefined)}
            class="text-sm text-primary transition-colors hover:text-accent"
          >
            Clear type
          </a>
        )
      }
    </div>

    <div class="flex flex-wrap gap-2">
      {
        types.map(type => (
          <a
            href={buildResourcesUrl({ category: selectedCategory, type, page: 1 }, searchQuery || undefined)}
            class={`rounded-full px-3 py-2 text-sm font-medium transition-colors ${
              selectedType === type ? 'bg-primary text-white' : 'hover:bg-muted-foreground/20 bg-muted text-foreground'
            }`}
          >
            {type}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Clear All Filters -->
  {
    (selectedCategory || selectedType) && (
      <div class="border-t border-border pt-4">
        <a
          href={buildResourcesUrl({ category: undefined, type: undefined, page: 1 }, searchQuery || undefined)}
          class="text-sm font-medium text-primary transition-colors hover:text-accent"
        >
          Clear all filters
        </a>
      </div>
    )
  }
</div>
